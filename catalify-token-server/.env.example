# Server port (nginx/Caddy should reverse-proxy HTTPS to this)
PORT=3000

# Apple Developer Team ID (10 chars, from developer.apple.com → Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# Key ID — matches the filename AuthKey_<KEY_ID>.p8
APPLE_KEY_ID=YYYYYYYYYY

# Absolute or relative path to the .p8 private key on THIS server
APPLE_PRIVATE_KEY_PATH=/etc/catalify/AuthKey_YYYYYYYYYY.p8

# Token TTL in seconds. Default = 150 days (Apple's max ~6 months).
TOKEN_TTL_SECONDS=12960000
