# ─────────────────────────────────────────────────────────────────
# Çatalify desktop client — environment config
# ─────────────────────────────────────────────────────────────────
#
# Apple Music credentials (TEAM_ID / KEY_ID / .p8) are NOT needed on
# this side anymore. They live on the VPS token server only. See
# `catalify-token-server/.env.example` for the server-side config.

# URL of your VPS signing server. Production clients ship with a
# hardcoded default in `dist-electron/main/developer-token.js`; this
# env var is for dev/local testing (e.g. running the token server on
# your own machine at :3000).
CATALIFY_TOKEN_ENDPOINT=http://localhost:3000/musickit-token

# Override Discord Rich Presence app ID for testing against your own
# Discord application. Leave blank to use Çatalify's production app.
DISCORD_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────
# Release / publish credentials — consumed by `npm run release`
# ─────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic) with `repo` scope. Used by
# electron-builder to upload the installer + latest.yml to a GitHub
# Release. NEVER commit this value — `.env` is gitignored.
GH_TOKEN=
