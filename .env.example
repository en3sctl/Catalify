# Apple Music / MusicKit credentials
# Get these from https://developer.apple.com/account

# Your 10-character Team ID (Apple Developer portal → Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# Key ID — matches the filename AuthKey_<KEY_ID>.p8
APPLE_KEY_ID=YYYYYYYYYY

# Path to the .p8 private key file (relative to project root)
APPLE_PRIVATE_KEY_PATH=./AuthKey_YYYYYYYYYY.p8

# ── OPTIONAL — Discord Rich Presence ────────────────────────────
# Create an app at https://discord.com/developers/applications,
# copy its "Application ID" here. Upload an icon asset named
# "catalify" for the large image and "play" / "pause" for the
# small status images. Leave blank to disable Discord presence.
DISCORD_CLIENT_ID=
